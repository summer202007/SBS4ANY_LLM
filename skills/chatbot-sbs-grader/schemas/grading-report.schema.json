{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GradingReport",
  "type": "object",
  "required": [
    "schemaVersion",
    "artifactType",
    "taskId",
    "packageId",
    "runId",
    "createdAt",
    "executiveVerdict",
    "decisionVerdicts",
    "evaluationValidity",
    "aggregateScores",
    "scoreInterpretation",
    "taskSpaceDimensionVerdicts",
    "keyEvidenceSnippets",
    "caseTable",
    "caseTypeBreakdown",
    "dimensionBreakdown",
    "redLineSummary",
    "failureClusters",
    "strengthPockets",
    "targetAudienceAndCommunicationInsights",
    "differentiatedValueAssessment",
    "challengerOptimizationPlan",
    "uncertaintyAndCaveats",
    "appendixRefs"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "artifactType": { "const": "GradingReport" },
    "taskId": { "type": "string" },
    "packageId": { "type": "string" },
    "runId": { "type": "string" },
    "createdAt": { "type": "string" },
    "executiveVerdict": {
      "type": "object",
      "required": ["verdict", "confidence", "headline", "summary", "sideOverallConclusions"],
      "properties": {
        "verdict": {
          "enum": [
            "challenger_wins",
            "baseline_wins",
            "meaningful_niche_win",
            "tie_or_inconclusive",
            "insufficient_evidence"
          ]
        },
        "confidence": { "enum": ["high", "medium", "low"] },
        "headline": { "type": "string" },
        "summary": { "type": "string" },
        "sideOverallConclusions": {
          "type": "object",
          "required": ["baseline", "challenger"],
          "properties": {
            "baseline": { "type": "string" },
            "challenger": { "type": "string" }
          },
          "additionalProperties": true
        },
        "coverageCaveat": { "type": "string" }
      },
      "additionalProperties": true
    },
    "evaluationValidity": { "type": "object" },
    "decisionVerdicts": {
      "type": "object",
      "required": ["taskUtility", "releaseSafetyReadiness"],
      "properties": {
        "taskUtility": { "$ref": "#/$defs/decisionVerdict" },
        "releaseSafetyReadiness": { "$ref": "#/$defs/decisionVerdict" }
      },
      "additionalProperties": true
    },
    "aggregateScores": {
      "type": "object",
      "required": ["scale", "dimensions"],
      "properties": {
        "scale": { "const": "0-100" },
        "overall": {
          "type": "object",
          "required": ["baselineScore", "challengerScore", "winner"],
          "properties": {
            "baselineScore": { "type": "number" },
            "challengerScore": { "type": "number" },
            "winner": { "type": "string" },
            "scoredCaseCount": { "type": "number" },
            "rationale": { "type": "string" }
          },
          "additionalProperties": true
        },
        "dimensions": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    },
    "scoreInterpretation": {
      "type": "object",
      "required": ["policy", "precisionCaveat"],
      "properties": {
        "policy": { "enum": ["directional_scores", "calibrated_scores"] },
        "precisionCaveat": { "type": "string" },
        "confidenceBandPolicy": { "type": "string" }
      },
      "additionalProperties": true
    },
    "taskSpaceDimensionVerdicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "dimensionId",
          "baselineScore",
          "challengerScore",
          "winner",
          "baselineConclusion",
          "challengerDiagnosis",
          "evidenceRefs"
        ],
        "properties": {
          "dimensionId": { "type": "string" },
          "baselineScore": { "type": "number" },
          "challengerScore": { "type": "number" },
          "winner": { "type": "string" },
          "baselineConclusion": { "type": "string" },
          "challengerDiagnosis": { "type": "string" },
          "evidenceRefs": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "keyEvidenceSnippets": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/evidenceSnippet" }
    },
    "caseTable": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "caseId": { "type": "string" },
          "caseType": { "type": "string" },
          "gradeReadiness": { "type": "string" },
          "winner": { "type": "string" },
          "baselineScore": { "anyOf": [{ "type": "number" }, { "type": "null" }] },
          "challengerScore": { "anyOf": [{ "type": "number" }, { "type": "null" }] },
          "confidence": { "type": "string" },
          "caveats": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "caseTypeBreakdown": { "type": "array", "items": { "type": "object" } },
    "dimensionBreakdown": { "type": "array", "items": { "type": "object" } },
    "redLineSummary": { "type": "array", "items": { "type": "object" } },
    "failureClusters": { "type": "array", "items": { "type": "object" } },
    "strengthPockets": { "type": "array", "items": { "type": "object" } },
    "targetAudienceAndCommunicationInsights": { "type": "array", "items": { "type": "object" } },
    "differentiatedValueAssessment": { "type": "object" },
    "challengerOptimizationPlan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["priority", "theme", "recommendation", "linkedDimensions", "evidenceRefs", "confidence"],
        "properties": {
          "priority": { "enum": ["high", "medium", "low"] },
          "theme": { "type": "string" },
          "recommendation": { "type": "string" },
          "whyItMatters": { "type": "string" },
          "executionIdeas": { "type": "array", "items": { "type": "string" } },
          "linkedDimensions": { "type": "array", "items": { "type": "string" } },
          "linkedCaseTypes": { "type": "array", "items": { "type": "string" } },
          "linkedFailureClusters": { "type": "array", "items": { "type": "string" } },
          "evidenceRefs": { "type": "array", "items": { "type": "string" } },
          "confidence": { "enum": ["high", "medium", "low"] },
          "speculative": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "uncertaintyAndCaveats": { "type": "array", "items": { "type": "object" } },
    "appendixRefs": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "decisionVerdict": {
      "type": "object",
      "required": ["winner", "confidence", "summary", "implication"],
      "properties": {
        "winner": { "type": "string" },
        "confidence": { "enum": ["high", "medium", "low", "none"] },
        "summary": { "type": "string" },
        "implication": { "type": "string" },
        "evidenceRefs": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "evidenceSnippet": {
      "type": "object",
      "required": ["caseId", "side", "field", "quote", "whyItMatters"],
      "properties": {
        "caseId": { "type": "string" },
        "turnIndex": { "type": "number" },
        "side": { "enum": ["baseline", "challenger"] },
        "field": { "type": "string" },
        "quote": { "type": "string" },
        "whyItMatters": { "type": "string" },
        "linkedClaim": { "type": "string" },
        "evidenceRef": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
