{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chatbot Website Capture Adapter Builder Output",
  "type": "object",
  "required": [
    "providerId",
    "mode",
    "fieldInventory",
    "extractionPlan",
    "normalizationMapper",
    "knownLimitations",
    "adapterReadiness"
  ],
  "properties": {
    "providerId": { "type": "string", "minLength": 1 },
    "providerName": { "type": "string", "minLength": 1 },
    "mode": {
      "type": "string",
      "enum": ["plan", "implementation", "qa", "isolation_regression"]
    },
    "fieldInventory": { "type": "object" },
    "extractionPlan": { "type": "object" },
    "normalizationMapper": { "type": "object" },
    "snapshotRequirements": { "type": "object" },
    "selectorHints": { "type": "object" },
    "turnBoundaryPlan": { "type": "object" },
    "providerUiPatterns": { "type": "object" },
    "reconRetryAdvice": {
      "type": "array",
      "items": { "type": "string" }
    },
    "qaExpectations": { "type": "object" },
    "qaResult": { "type": "object" },
    "knownLimitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "manualFallbackInstructions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "adapterReadiness": {
      "type": "string",
      "enum": ["ready", "partial", "blocked"]
    }
  },
  "additionalProperties": true
}
